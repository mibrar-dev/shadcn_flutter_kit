{
  "id": "patch",
  "name": "Click Detector",
  "description": "Tracks consecutive taps and exposes click count details.",
  "category": "control",
  "tier": "primitive",
  "tags": [
    "gesture",
    "interaction",
    "utility"
  ],
  "dependencies": {
    "shared": [],
    "components": [],
    "pubspec": {}
  },
  "files": [
    "_impl/core/click_detector.dart",
    "_impl/state/click_detector_state.dart",
    "_impl/state/patch_preview_state.dart",
    "_impl/utils/click_details.dart",
    "patch.dart"
  ],
  "api": {
    "constructors": [
      "`ClickDetector`",
      "`child` (`Widget`, required)",
      "`onClick` (`ClickCallback<ClickDetails>?`)",
      "`behavior` (`HitTestBehavior`, default: `deferToChild`)",
      "`threshold` (`Duration`, default: `300ms`)"
    ],
    "callbacks": [
      "`onClick` — receives `ClickDetails` with `clickCount`."
    ]
  },
  "version": "1.0.0"
