{
  "id": "filter_bar",
  "name": "Filter Bar",
  "description": "Controlled filter toolbar for list/table pages with search, sort, chips, date range, and clear-all.",
  "category": "layout",
  "tier": "pattern",
  "assets": [],
  "fonts": [],
  "version": "1.0.0",
  "tags": [
    "layout",
    "filter_bar",
    "filter",
    "search",
    "sort"
  ],
  "dependencies": {
    "shared": [
      "theme",
      "lucide_icons",
      "localizations"
    ],
    "components": [
      "button",
      "chip",
      "calendar",
      "checkbox",
      "text_field",
      "select",
      "date_picker",
      "form_field",
      "drawer",
      "scaffold"
    ],
    "pubspec": {}
  },
  "files": [
    "_impl/core/filter_bar_content.dart",
    "_impl/extensions/filter_state_extensions.dart",
    "_impl/state/filter_bar_controller.dart",
    "_impl/state/filter_bar_state.dart",
    "_impl/styles/filter_bar_style.dart",
    "_impl/themes/base/filter_bar_theme.dart",
    "_impl/themes/config/filter_bar_theme_config.dart",
    "_impl/themes/config/filter_bar_theme_defaults.dart",
    "_impl/themes/config/filter_bar_theme_schema.dart",
    "_impl/themes/config/filter_bar_theme_tokens.dart",
    "_impl/utils/filter_bar_utils.dart",
    "_impl/variants/filter_bar_layout.dart",
    "filter_bar.dart",
    "filter_bar_logic.dart"
  ],
  "api": {
    "constructors": [
      "`FilterBar`",
      "`state` (`FilterState?`, required when `controller` is not provided)",
      "`onStateChanged` (`ValueChanged<FilterState>?`, required when `controller` is not provided)",
      "`controller` (`FilterBarController?`, optional)",
      "`sortOptions` (`List<FilterSortOption>`, optional)",
      "`enableDateRange` (`bool`, optional)",
      "`resultsCount` (`int?`, optional)",
      "`searchPlaceholder` (`String`, optional)",
      "`searchLabel` (`String`, optional)",
      "`searchDebounce` (`Duration?`, optional)",
      "`trailingFilters` (`List<Widget>`, optional)",
      "`customFilters` (`List<FilterCustomFilter>`, optional)",
      "`style` (`FilterBarStyle?`, optional)",
      "`clearPolicy` (`FilterClearPolicy`, optional)",
      "`onClearAll` (`FilterState Function(FilterState current)?`, optional)",
      "`showClearAllWhenEmpty` (`bool`, optional)",
      "`presentation` (`FilterBarPresentation`, optional, default: `autoSheet`)",
      "`sheetBreakpoint` (`double`, optional, default: `720`)",
      "`sheetTriggerLabel` (`String`, optional)",
      "`sheetTitle` (`String`, optional)",
      "`sheetPosition` (`OverlayPosition`, optional, default: `OverlayPosition.bottom`)",
      "`groups` (`List<FilterGroup>`, optional)",
      "`clearPolicy.clearCustomFilters` (`bool`, optional, default: `true`)"
    ],
    "callbacks": [
      "`onStateChanged` emits the next `FilterState` whenever the UI changes.",
      "`onClearAll` optionally overrides clear-all behavior with custom policy logic."
    ]
  }
}
